<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ================================= Resistance Weapons ==================================== -->
  
      <!-- ================================= Auger Mk II ==================================== -->  
   <ThingDef ParentName="RNMakeableSpacer">
    <defName>RNSci_AugerMkII</defName>
    <label>Auger Mk II</label>
    <description>The Auger Mark II is an upgraded version of the standard Auger Rifle, allows users to aim at targets and fire through walls. The Auger Mark II comes with a transparent visor which reveals the thermal signature of any enemies through walls, making the Mark II perfect for neutralizing enemies without having to guess where they are as with the previous Auger.
	
The transient radiation charges of the Auger Mk II has improved firepower, along with the better accuracy that the rifle now has.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Things/Item/Equipment/Spacer/Auger</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <statBases>
      <WorkToMake>60000</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>0.75</AccuracyTouch>
      <AccuracyShort>0.81</AccuracyShort>
      <AccuracyMedium>0.72</AccuracyMedium>
      <AccuracyLong>0.63</AccuracyLong>
      <RangedWeapon_Cooldown>1.80</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Plasma_Component>1</Plasma_Component>
      <Weapon_Parts>5</Weapon_Parts>
      <ComponentSpacer>9</ComponentSpacer>
      <ComponentAdvanced>11</ComponentAdvanced>
      <Plasteel>17</Plasteel>
    </costList>




    <weaponTags>
      <!--<li>RN_SpacerGun</li>-->
	  <li>RN_AugerMkII</li>
    </weaponTags>
	
	<equippedAngleOffset>40</equippedAngleOffset>
	
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>RNBullet_AugerMkII</defaultProjectile>
        <warmupTime>1.2</warmupTime>
        <range>30</range>
        <ticksBetweenBurstShots>8</ticksBetweenBurstShots>
        <burstShotCount>3</burstShotCount>
        <soundCast>RNAugerMkIIShot</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
		<onlyManualCast>false</onlyManualCast>
		<requireLineOfSight>false</requireLineOfSight>
		<stopBurstWithoutLos>false</stopBurstWithoutLos>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>RNBullet_AugerMkII</defName>
    <label>Transient Radiation charge</label>
    <graphicData>
      <texPath>Things/Projectile/Proj_AugerMkII</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>RNBullet_Charge</damageDef>
      <damageAmountBase>25</damageAmountBase>
	  <stoppingPower>3</stoppingPower>
	  <armorPenetrationBase>2.5</armorPenetrationBase>
      <speed>70</speed>
    </projectile>
		<modExtensions>
	  <li Class="CPWeaponExt.ProjectileExtension">
	    <passesWalls>true</passesWalls>
	  </li>
	</modExtensions>
  </ThingDef>

