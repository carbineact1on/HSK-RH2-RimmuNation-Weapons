<?xml version="1.0" encoding="utf-8"?>
<Defs>  

  <!-- ==================== HE grenade ========================== -->

	<ThingDef ParentName="RNMakeableGrenade">
		<defName>RNThrown_RGD5HEGrenade</defName>
		<label>RGD-5 grenades</label>
		<description>The RGD-5 High Explosive Grenade is essentially a capsule filled with explosives that will detonate on a timed fuse after being thrown.</description>
    <tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Item/Equipment/Grenade/RGD5_Grenade</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.85</drawSize>
		</graphicData>
		<soundInteract>Interact_Grenade</soundInteract>
		<techLevel>Industrial</techLevel>
		<statBases>
			<Mass>1</Mass>
			<RangedWeapon_Cooldown>5.5</RangedWeapon_Cooldown>
      <WorkToMake>12000</WorkToMake>
    </statBases>
    <costList>
      <Steel>20</Steel>
      <Chemfuel>80</Chemfuel>
    </costList>
		<weaponTags>
			<li>GrenadeDestructive</li>
			<li>RN_HEGrenade</li>
		</weaponTags>
		<!--<thingCategories>
			<li>Grenades</li>
		</thingCategories>-->
		<verbs>
			<li>
				<label>throw HE grenade</label>
				<verbClass>Verb_LaunchProjectile</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<range>13.9</range>
				<forcedMissRadius>1.0</forcedMissRadius>
				<warmupTime>3.4</warmupTime>
				<noiseRadius>4</noiseRadius>
				<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
				<soundCast>ThrowGrenade</soundCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<defaultProjectile>RNProj_RGHEGrenade</defaultProjectile>
        <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>
    <comps>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>2.75</explosiveRadius>
        <explosiveDamageType>RN2FragBomb</explosiveDamageType>
        <requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
      </li>
    </comps>
	</ThingDef>

	<ThingDef ParentName="BaseGrenadeProjectile">
		<defName>RNProj_RGHEGrenade</defName>
		<label>RGD-5 grenade</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/RGD5_Thrown</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.1</drawSize>
		</graphicData>
		<projectile>
			<explosionRadius >2.8</explosionRadius >
			<damageDef>RN2FragBomb</damageDef>
      <!-- Use default damage from explosion def -->
			<explosionDelay>100</explosionDelay>
			<stoppingPower>2</stoppingPower>
		</projectile>
	</ThingDef>
	
  <!-- STUN NADE -->
  
    <ThingDef ParentName="BaseGun">
    <defName>RNThrown_M84Stun_Grenade</defName>
    <label>M84 stun grenade</label>
    <description>The M84 is the currently-issued stun grenade ("flashbang") of the United States Armed Forces and SWAT teams throughout the United States. Upon detonation, it emits an intensely loud "bang" of 170–180 decibels and a blinding flash of more than one million candela within five feet of initiation, sufficient to cause immediate flash blindness, deafness, tinnitus, and inner ear disturbance.</description>
    <tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Item/Equipment/Grenade/M84_StunGrenade</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_Grenade</soundInteract>
    <techLevel>Industrial</techLevel>
    <statBases>
      <Mass>1</Mass>
      <RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
      <WorkToMake>24000</WorkToMake>
    </statBases>
    <costList>
      <Steel>20</Steel>
      <ComponentIndustrial>6</ComponentIndustrial>
    </costList>
    <weaponTags>
      <li>GrenadeEMP</li>
	  <li>RN_M84Stun</li>
    </weaponTags>
    <thingCategories>
      <li>Grenades</li>
    </thingCategories>
    <verbs>
      <li>
        <label>throw m84 stun grenade</label>
        <verbClass>Verb_LaunchProjectile</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <range>15</range>
        <forcedMissRadius>2.0</forcedMissRadius>
        <warmupTime>3</warmupTime>
        <noiseRadius>4</noiseRadius>
        <ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
        <soundCast>ThrowGrenade</soundCast>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <defaultProjectile>RNProjectile_M84Stun_Grenade</defaultProjectile>
        <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
      </li>
    </verbs>
    <comps>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>3.5</explosiveRadius>
        <explosiveDamageType>Stun</explosiveDamageType>
        <requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
      </li>
    </comps>
  </ThingDef>
  
  	<ThingDef ParentName="BaseGrenadeProjectile">
		<defName>RNProjectile_M84Stun_Grenade</defName>
		<label>M84 stun grenade</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/M84Stun_Thrown</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.0</drawSize>
		</graphicData>
		<projectile>
			<explosionRadius>3.5</explosionRadius>
			<damageDef>Stun</damageDef>
			<damageAmountBase>15</damageAmountBase>
			<explosionDelay>75</explosionDelay>
		</projectile>
	</ThingDef>

</Defs>