  <!-- AA-12 (Modern - Plastic) -->
  <RecipeDef ParentName="RangedWeaponRecipeBase">
    <defName>Build_RNGun_AA12_Shotgun</defName>
    <label>Build AA-12</label>
    <description>Build AA-12.</description>
    <jobString>Building AA-12.</jobString>
    <workAmount>16000</workAmount>
    <skillRequirements><Crafting>6</Crafting></skillRequirements>
    <ingredients>
      <li><filter><thingDefs><li>Shotgun_Component</li></thingDefs></filter><count>1</count></li>
      <li><filter><thingDefs><li>Weapon_Parts</li></thingDefs></filter><count>4</count></li>
      <li><filter><thingDefs><li>ComponentIndustrial</li></thingDefs></filter><count>6</count></li>
      <li><filter><categories><li>Metallic</li></categories></filter><count>20</count></li>
      <li><filter><thingDefs><li>Plastic</li></thingDefs></filter><count>16</count></li>
    </ingredients>
    <products><RNGun_AA12_Shotgun>1</RNGun_AA12_Shotgun></products>
    <fixedIngredientFilter>
      <thingDefs><li>Shotgun_Component</li><li>Weapon_Parts</li><li>ComponentIndustrial</li><li>Plastic</li></thingDefs>
      <categories><li>SLDBar</li><li>USLDBar</li></categories>
    </fixedIngredientFilter>
    <recipeUsers><li>WeaponCraftingWorkTable</li></recipeUsers>
    <researchPrerequisite>GasOperation</researchPrerequisite>
  </RecipeDef>

