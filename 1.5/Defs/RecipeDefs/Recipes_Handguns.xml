    <defName>Build_RNGun_ColtCobra_Revolver</defName>
    <label>Build Colt Cobra</label>
    <description>Build Colt Cobra.</description>
    <jobString>Building Colt Cobra.</jobString>
    <workAmount>8000</workAmount>
    <skillRequirements>
      <Crafting>4</Crafting>
    </skillRequirements>
    <ingredients>
      <li>
        <filter><thingDefs><li>Pistol_Component</li></thingDefs></filter>
        <count>1</count>
      </li>
      <li>
        <filter><thingDefs><li>Weapon_Parts</li></thingDefs></filter>
        <count>2</count>
      </li>
      <li>
        <filter><thingDefs><li>ComponentIndustrial</li></thingDefs></filter>
        <count>3</count>
      </li>
      <li>
        <filter><categories><li>Metallic</li></categories></filter>
        <count>10</count>
      </li>
      <li>
        <filter><categories><li>Woody</li></categories></filter>
        <count>8</count>
      </li>
    </ingredients>
    <products><RNGun_ColtCobra_Revolver>1</RNGun_ColtCobra_Revolver></products>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Pistol_Component</li>
        <li>Weapon_Parts</li>
        <li>ComponentIndustrial</li>
        
      </thingDefs>
      <categories>
        <li>SLDBar</li>
        <li>USLDBar</li>
        <li>Leathers</li>
      <li>Woody</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>WeaponCraftingWorkTable</li>
    </recipeUsers>
    <researchPrerequisite>Gunsmithing</researchPrerequisite>
  </RecipeDef>

