	<!-- RPG-7 (WoodLog) -->
	<RecipeDef ParentName="RangedWeaponRecipeBase">
		<defName>Build_RN_RPG7</defName>
		<label>Build RPG-7</label>
		<description>Builds an RPG-7 rocket-propelled grenade launcher.</description>
		<jobString>Building RPG-7.</jobString>
		<workAmount>22000</workAmount>
		<skillRequirements>
			<Crafting>10</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Launcher_Component</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Weapon_Parts</li>
					</thingDefs>
				</filter>
				<count>6</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>6</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>Metallic</li>
					</categories>
				</filter>
				<count>22</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						
					</thingDefs>
				</filter>
				<count>22</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>Leathers</li>
      <li>Woody</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<products>
			<RNGun_RPG7_RocketLauncher>1</RNGun_RPG7_RocketLauncher>
		</products>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Launcher_Component</li>
				<li>Weapon_Parts</li>
				<li>ComponentIndustrial</li>
				
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>Leathers</li>
      <li>Woody</li>
			</categories>
		</fixedIngredientFilter>
		<recipeUsers>
			<li>AdvWeaponCraftingWorkTable</li>
		</recipeUsers>
		<researchPrerequisite>Rockets_C1</researchPrerequisite>
	</RecipeDef>

