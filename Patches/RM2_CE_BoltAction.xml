	<!-- == Shared patches for firearm melee tools == -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[
			defName="RNGun_C14Timberwolf_Sniper" or
			defName="RNGun_DesertTechHTI_AMR" or
			defName="RNGun_GOLMagnum_Sniper" or
			defName="RNGun_L96A1_Sniper" or
			defName="RNGun_M24A2_Sniper" or
			defName="RNGun_M40A5_Sniper" or
			defName="RNGun_M200Intervention_AMR" or
			defName="RNGun_M700SAICS_Sniper"
			]/tools </xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>stock</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<cooldownTime>1.55</cooldownTime>
					<chanceFactor>1.5</chanceFactor>
					<armorPenetrationBlunt>2.755</armorPenetrationBlunt>
